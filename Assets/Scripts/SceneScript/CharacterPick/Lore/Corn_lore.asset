  lore: "\uFF21\u30DC\u30BF\u30F3\uFF1A\u7206\u767A\u30B3\u30FC\u30F3\u5C04\u51FA\n\uFF08\u7740\u5F3E\u3067\u7206\u767A\uFF09\n\n\uFF22\u30DC\u30BF\u30F3\uFF1A\u5730\u96F7\u8A2D\u7F6E\n\uFF08\u6575\u306B\u63A5\u89E6\u3067\u7206\u767A\u3001\u79FB\u52D5\u963B\u5BB3\u3092\u4ED8\u4E0E\uFF09\n\n\u30D0\u30FC\u30B9\u30C8\u30B2\u30FC\u30B8\u306B\u5FDC\u3058\u3066\u79FB\u52D5\u901F\u5EA6\u304C\u4E0A\u6607\uFF01"
